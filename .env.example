APP_NAME="Cine Lumière"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lumiere
DB_USERNAME=lumiere
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@lumiere.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── TMDB API ────────────────────────────────────────────────────────────────
# Obtén tu clave gratuita en https://www.themoviedb.org/settings/api
# El comando `php artisan tmdb:sync` la usa para importar películas a la BD.
# Déjala vacía para desactivar la integración TMDB.
TMDB_API_KEY=

SERVICES_MOVIES_API_ENABLED=true
SERVICES_MOVIES_API_BASE_URL=https://api.themoviedb.org/3
SERVICES_MOVIES_API_API_KEY="${TMDB_API_KEY}"
SERVICES_MOVIES_API_LANGUAGE=es-ES
SERVICES_MOVIES_API_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
SERVICES_MOVIES_API_TIMEOUT=8

# ── Redis (opcional, para colas y caché) ────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Variables para despliegue en Railway.app ────────────────────────────────
# APP_KEY  → generada con: php artisan key:generate --show
# DB_*     → proporcionadas por el servicio MySQL de Railway
# TMDB_API_KEY → tu clave TMDB
